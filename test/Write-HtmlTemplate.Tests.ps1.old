<#
.SYNOPSIS
	Tests the features of the `Write-HtmlTemplate` cmdlets.
#>
Describe "Write-HtmlTemplate" {
	BeforeAll {
		Import-Module "$PSScriptRoot/../Html.psd1"
	}

	It "should render to HTML the given template" {
		$html = include "$PSScriptRoot/../res/Document.ps1"
		$html | Should -BeLikeExactly "<!doctype html>*"
		$html | Should -BeLikeExactly '* dir="ltr"*'
		$html | Should -BeLikeExactly '* lang="fr-FR"*'
	}
}
